rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own app state (favorites, current service)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Service data (protocols, meds, contacts) — all authenticated users can read,
    // only the admin account can write
    match /service_data/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                      request.auth.token.email == 'eliasacaldwellnrp@gmail.com';
    }

    // ToS acceptance log — user can create/update their own record;
    // only admin can read the full collection
    match /tos_acceptances/{uid} {
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null &&
                     request.auth.token.email == 'eliasacaldwellnrp@gmail.com';
    }

    // Shift rosters — any authenticated user can read/write (supervisors share shift data)
    match /shift_rosters/{date} {
      allow read, write: if request.auth != null;
    }

    // Custom employees — admin-only (only the supervisor account can manage)
    match /custom_employees/{empId} {
      allow read, write: if request.auth != null &&
                            request.auth.token.email == 'eliasacaldwellnrp@gmail.com';
    }
  }
}
