rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Role helpers ──
    // Admins have full management rights (incl. editing other users' access).
    // Supervisors are a superset-of-crew role with elevated app access; every
    // admin is also a supervisor.
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email in [
               'eliasacaldwellnrp@gmail.com'
             ];
    }
    function isSupervisor() {
      return request.auth != null && (
        request.auth.token.email in [
          'eliasacaldwellnrp@gmail.com',
          'smcdonel@easimedics.com'
        ] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('apps', []).hasAny(['supervisor']))
      );
    }

    // Users can read/write their own profile; admins can read/write all
    // profiles (this is what powers the User Access Management menu).
    // This covers both the top-level doc (email, uid, lastSeen, apps) and
    // any subcollections (e.g. pearls).
    match /users/{userId} {
      allow read:  if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Per-user app data (favourites, shift checklist, UCO, supply sheet, etc.)
    match /users/{userId}/appdata/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can read/write their own pearls subcollection
    match /users/{userId}/pearls/{pearlId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Service data (protocols, meds, contacts) — all authenticated users can read,
    // only the admin account can write
    match /service_data/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ToS acceptance log — user can create/update their own record;
    // only admin can read the full collection
    match /tos_acceptances/{uid} {
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    // Shift rosters — any authenticated user can read/write (crews share shift data).
    // Both the legacy top-level path and the per-service nested path are covered.
    match /shift_rosters/{date} {
      allow read, write: if request.auth != null;
    }
    match /services/{serviceId}/shift_rosters/{date} {
      allow read, write: if request.auth != null;
    }

    // Custom employees — managed from Supervisor Tools, so supervisors (and admins) may manage.
    // Both the legacy top-level path and the per-service nested path are covered.
    match /custom_employees/{empId} {
      allow read, write: if isSupervisor();
    }
    match /services/{serviceId}/custom_employees/{empId} {
      allow read, write: if isSupervisor();
    }

    // Supervisor config (station info, emp profiles) — synced across devices for supervisors.
    match /services/{serviceId}/config/{doc} {
      allow read, write: if isSupervisor();
    }

    // Activity log and shift reports — written by supervisors, readable by any authenticated user.
    match /services/{serviceId}/activity_log/{date} {
      allow read, write: if request.auth != null;
    }
    match /services/{serviceId}/shift_reports/{date} {
      allow read, write: if request.auth != null;
    }
  }
}
